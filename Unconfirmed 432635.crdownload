      "outputs": [],
      "source": [
        "#1.MNIST\n",
        "#2.classification DL\n",
        "#3.نحدد اي الصوره اللي تدخل من ضمن ال 10 اللي عندنا\n",
        "#4.consisting of a training set of 60,000 examples and a test set of 10,000\n",
        "#5.ال input صور ال output من 0ل9 كل رقم بيمثل نوع"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# import kagglehub\n",
        "\n",
        "# Download latest version\n",
        "# path = kagglehub.dataset_download(\"zalando-research/fashionmnist\")\n",
        "\n",
        "# print(\"Path to dataset files:\", path) ###local file"
      ],
      "metadata": {
        "id": "yBO7luHTfr8-"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import tensorflow as tf\n",
        "import numpy as np\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import Dense\n",
        "from tensorflow import keras\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt"
      ],
      "metadata": {
        "id": "M9OIStsnhafY"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from tensorflow.keras.datasets import fashion_mnist\n",
        "(X_train, y_train), (X_test, y_test) = fashion_mnist.load_data()"
      ],
      "metadata": {
        "id": "YU0L_I6ZbTZQ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(X_train.shape)#train shape\n",
        "print(X_test.shape)#test shape\n",
        "print(y_train.shape)#label معناه ان لكل صوره واحد"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "dRIJ0u_hcT07",
        "outputId": "279b2e74-0cab-471e-acf4-cf4d90fe9164"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "(60000, 28, 28)\n",
            "(10000, 28, 28)\n",
            "(60000,)\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "plt.imshow(X_train[0], cmap=\"gray\")#visualization\n",
        "plt.axis(\"off\")#hide ma7awer\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 406
        },
        "id": "wroYSZwddbkj",
        "outputId": "1ef8dd8c-f23e-466e-aae6-497f6dcf23f5"
      },
      "execution_count": null,
