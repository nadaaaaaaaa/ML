            "0 6000\n",
            "1 6000\n",
            "2 6000\n",
            "3 6000\n",
            "4 6000\n",
            "5 6000\n",
            "6 6000\n",
            "7 6000\n",
            "8 6000\n",
            "9 6000\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Define** **model**"
      ],
      "metadata": {
        "id": "iRCKa2fBNprT"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "model= Sequential([\n",
        "    Dense(128,activation=\"relu\",input_shape=(784,)),\n",
        "    Dense(64,activation=\"relu\"),\n",
        "    Dense(10,activation=\"softmax\")\n",
        "])"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
