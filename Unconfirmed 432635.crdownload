    },
    {
      "cell_type": "code",
      "source": [
        "#بحول من ان الصوره من 0ل255 ل احتماليه بين ال0و1\n",
        "X_train=X_train/255.0\n",
        "X_test=X_test/255.0\n",
        "#نعمل check\n",
        "print(X_train.min(),X_train.max())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "6C3YIpt-e1pm",
        "outputId": "2b349414-f7d1-45f6-8c95-03279471630a"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "0.0 1.0\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#هنا حولنا من 28*28 ل صف واحد vector  عباره عن 784\n",
        "X_train = X_train.reshape(-1, 28*28)\n",
        "X_test = X_test.reshape(-1, 28*28)\n",
        "print(X_train.shape)\n",
        "print(X_test.shape)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "TBt9ivr6fwlC",
        "outputId": "f4c8c484-14c7-4d6a-8061-1122a25b6acb"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "(60000, 784)\n",
            "(10000, 784)\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "## #pta000"
      ],
      "metadata": {
        "id": "IISizuRoGorJ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from enum import unique\n",
        "#imbalance?\n",
        "unique, counts = np.unique(y_train, return_counts=True)\n",
        "for u,c in zip(unique,counts):\n",
        "  print(u,c) # دا معناه ان اللي ظهر ان كل كلاس فيه 6000 صوره ودا يدل انها متوازنه"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "uQrNV6urjTvi",
        "outputId": "c69fe1de-a8d9-4ffe-d76f-ea330840f8c5"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
