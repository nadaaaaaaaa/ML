    {
      "cell_type": "code",
      "source": [
        "plt.plot(history.history[\"accuracy\"],label=\"train acc\")\n",
        "plt.plot(history.history[\"val_accuracy\"],label=\"val_acc\")\n",
        "plt.legend()\n",
        "plt.show()"
