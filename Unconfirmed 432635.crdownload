    {
      "cell_type": "markdown",
      "source": [
        "**compile model**"
      ],
      "metadata": {
        "id": "Ykd-iYOXRVvr"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "model.compile(\n",
        "    optimizer=\"adam\",\n",
        "    loss=\"sparse_categorical_crossentropy\",#لان التارجت بقي من 0ل9\n",
        "    metrics=[\"accuracy\"]\n",
        ")"
      ],
      "metadata": {
        "id": "PUe6F23xPigH"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "train"
      ],
      "metadata": {
        "id": "Py0xfGJigFiY"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "history=model.fit(\n",
        "    X_train,y_train,\n",
        "    epochs=10,\n",
        "    batch_size=32,\n",
        "    validation_split=.2\n",
        ")"
      ],
      "metadata": {
