    {
      "cell_type": "code",
      "source": [
        "import random\n",
        "\n",
        "class QLearningAgent:\n",
        "    def __init__(self, alpha=0.1, gamma=0.9, epsilon=0.2):\n",
        "        self.Q = {}  # Q-Tableذاكره ال Ai\n",
        "        self.alpha = alpha  # Learning Rate\n",
        "        self.gamma = gamma  # Discount Factor\n",
        "        self.epsilon = epsilon  # Exploration\n",
        "\n",
        "    def get_state(self, game):\n",
        "        return tuple(game.board.flatten())\n",
        "\n",
        "    def choose_action(self, game):\n",
        "        state = self.get_state(game)\n",
        "        moves = game.available_actions()\n",
        "\n",
        "        # Exploration\n",
        "        if random.random() < self.epsilon:\n",
        "            return random.choice(moves)\n",
        "\n",
        "        # Exploitation\n",
        "        if state not in self.Q:\n",
        "            self.Q[state] = {}\n",
        "\n",
        "        values = []\n",
        "        for move in moves:\n",
        "            values.append(self.Q[state].get(move, 0))\n",
        "\n",
        "        max_value = max(values)\n",
        "\n",
        "        best_moves = [move for move in moves if self.Q[state].get(move, 0) == max_value]\n",
        "\n",
        "        return random.choice(best_moves)\n",
        "\n",
        "    def update(self, state, action, reward, next_state):\n",
        "        if state not in self.Q:\n",
        "            self.Q[state] = {}\n",
        "\n",
        "        old_value = self.Q[state].get(action, 0)\n",
        "\n",
        "        next_max = 0\n",
        "        if next_state in self.Q:\n",
        "            next_max = max(self.Q[next_state].values(), default=0)\n",
        "\n",
        "        new_value = old_value + self.alpha * (\n",
        "            reward + self.gamma * next_max - old_value\n",
        "        )\n",
        "\n",
        "        self.Q[state][action] = new_value\n"
      ],
      "metadata": {
        "id": "6b8lzRtTKk6A"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Train"
      ],
      "metadata": {
        "id": "lrnzGq3nriCg"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def train(agent, episodes=5000):\n",
        "    game = TicTacToe()\n",
        "\n",
        "    for episode in range(episodes):\n",
        "        game.reset()\n",
        "        state = agent.get_state(game)\n",
        "\n",
        "        while True:\n",
        "            action = agent.choose_action(game)\n",
        "            game.make_move(action[0], action[1], 1)\n",
        "\n",
        "            winner = game.is_game_over()\n",
        "\n",
        "            if winner is not None:\n",
        "                reward = 1 if winner == 1 else 0\n",
        "                agent.update(state, action, reward, agent.get_state(game))\n",
        "                break\n",
        "\n",
        "            # random\n",
        "            opp_move = random.choice(game.available_moves())\n",
        "            game.make_move(opp_move[0], opp_move[1], -1)\n",
        "\n",
        "            winner = game.is_game_over()\n",
        "\n",
        "            next_state = agent.get_state(game)\n",
        "\n",
        "            if winner is not None:\n",
        "                reward = -1 if winner == -1 else 0\n",
        "                agent.update(state, action, reward, next_state)\n",
        "                break\n",
        "\n",
        "            agent.update(state, action, 0, next_state)\n",
        "            state = next_state\n"
      ],
      "metadata": {
        "id": "JRxhf71sLsft"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "agent = QLearningAgent()\n",
        "train(agent, episodes=10000)\n"
      ],
