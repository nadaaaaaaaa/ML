      "source": [
        "import numpy as np\n",
        "class TicTacToe:#لعبه x,o\n",
        "  def __init__(self):\n",
        "    self.board = np.zeros((3,3))\n",
        "  def reset(self):\n",
        "    self.board = np.zeros((3,3))\n",
        "  def available_actions(self):\n",
        "      actions = []\n",
        "      for i in range(3):\n",
        "        for j in range(3):\n",
        "          if self.board[i,j] == 0:\n",
        "            actions.append((i,j))\n",
        "      return actions\n",
        "  def make_move(self, row,column, player):\n",
        "    if self.board[row,column] == 0:\n",
        "      self.board[row,column] = player\n",
        "      return True\n",
        "    else:\n",
        "      return False\n",
        "  def is_game_over(self):\n",
        "    for i in range(3):\n",
        "      if abs(np.sum(self.board[i,:])) == 3:\n",
        "        return self.board[i, 0]\n",
        "      if abs(np.sum(self.board[:,i])) == 3:\n",
        "        return self.board[0, i]\n",
        "\n",
        "      diag1 = sum(self.board[i, i] for i in range(3))\n",
        "      diag2 = sum(self.board[i, 2 - i] for i in range(3))\n",
        "\n",
        "      if abs(diag1) == 3:\n",
        "        return self.board[0, 0]\n",
        "\n",
        "      if abs(diag2) == 3:\n",
        "          return self.board[0, 2]\n",
        "\n",
        "      if len(self.available_actions()) == 0:\n",
        "        return True\n",
        "      else:\n",
        "        return False\n",
        "\n",
        "  def print_board(self):\n",
        "    symbols = {0: \".\", 1: \"X\", -1: \"O\"}\n",
        "\n",
        "    for row in self.board:\n",
        "        print(\" \".join(symbols[int(cell)] for cell in row))\n",
        "\n",
        "    print()\n"
      ]
    },
