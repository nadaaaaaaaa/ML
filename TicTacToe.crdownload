        "        col = int(input(\"Col (1-2): \"))\n",
        "\n",
        "        valid = game.make_move(row, col, 1)\n",
        "\n",
        "        if not valid:\n",
        "            print(\"Invalid move!\")\n",
        "            continue\n",
        "\n",
        "    else:\n",
        "        move = agent.choose_action(game)  # هنا الفرق\n",
        "        print(\"AI move:\", move)\n",
        "        game.make_move(move[0], move[1], -1)\n",
        "\n",
        "    current_player *= -1\n"
