        "\n",
        "    if winner is not None:\n",
        "        if winner == 1:\n",
        "            print(\"You Wins\")\n",
        "        elif winner == -1:\n",
        "            print(\"AI Wins\")\n",
        "        else:\n",
        "            print(\"Draw\")\n",
        "        break\n",
        "\n",
        "    if current_player == 1:\n",
