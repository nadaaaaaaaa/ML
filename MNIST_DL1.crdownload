#1.MNIST
#2.classification DL
#3.نحدد اي الصوره اللي تدخل من ضمن ال 10 اللي عندنا
#4.consisting of a training set of 60,000 examples and a test set of 10,000
#5.ال input صور ال output من 0ل9 كل رقم بيمثل نوع

# import kagglehub

# Download latest version
# path = kagglehub.dataset_download("zalando-research/fashionmnist")

# print("Path to dataset files:", path) ###local file

import tensorflow as tf
import numpy as np
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense
from tensorflow import keras
import numpy as np
import matplotlib.pyplot as plt

from tensorflow.keras.datasets import fashion_mnist
(X_train, y_train), (X_test, y_test) = fashion_mnist.load_data()

print(X_train.shape)#train shape
print(X_test.shape)#test shape
print(y_train.shape)#label معناه ان لكل صوره واحد

plt.imshow(X_train[0], cmap="gray")#visualization
plt.axis("off")#hide ma7awer
plt.show()

#بحول من ان الصوره من 0ل255 ل احتماليه بين ال0و1
X_train=X_train/255.0
X_test=X_test/255.0
#نعمل check
print(X_train.min(),X_train.max())

#هنا حولنا من 28*28 ل صف واحد vector  عباره عن 784
X_train = X_train.reshape(-1, 28*28)
X_test = X_test.reshape(-1, 28*28)
print(X_train.shape)
print(X_test.shape)

"""## #pta000"""

from enum import unique
#imbalance?
unique, counts = np.unique(y_train, return_counts=True)
for u,c in zip(unique,counts):
  print(u,c) # دا معناه ان اللي ظهر ان كل كلاس فيه 6000 صوره ودا يدل انها متوازنه

"""**Define** **model**"""

model= Sequential([
    Dense(128,activation="relu",input_shape=(784,)),
    Dense(64,activation="relu"),
    Dense(10,activation="softmax")
])

model.summary()#the none ,mean momken 1photo or more

"""**compile model**"""

model.compile(
    optimizer="adam",
    loss="sparse_categorical_crossentropy",#لان التارجت بقي من 0ل9
    metrics=["accuracy"]
)

"""train"""

history=model.fit(
    X_train,y_train,
    epochs=10,
    batch_size=32,
    validation_split=.2
)

plt.plot(history.history["loss"],label="loss")
plt.plot(history.history["val_loss"],label="val_loss")
plt.legend()
plt.show()

plt.plot(history.history["accuracy"],label="train acc")
plt.plot(history.history["val_accuracy"],label="val_acc")
plt.legend()
plt.show()

"""***`Evaluate`***"""

test_loss,test_acc=model.evaluate(X_test,y_test)
print(test_loss,test_acc)

